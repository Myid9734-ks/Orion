<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OKXTradingBot.UI.Views.LicenseErrorDialog"
        Title="라이센스 인증"
        Width="520" Height="380"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        SystemDecorations="BorderOnly"
        Background="#1E1E2E">

  <Border Padding="24" CornerRadius="10"
          Background="#1E1E2E"
          BorderBrush="#3A3A5C" BorderThickness="1">
    <StackPanel Spacing="14">

      <!-- 타이틀 -->
      <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
        <TextBlock Text="🔒" FontSize="24" VerticalAlignment="Center"/>
        <TextBlock Text="라이센스 인증 실패"
                   FontSize="15" FontWeight="Bold"
                   Foreground="#FF5555"
                   VerticalAlignment="Center"/>
      </StackPanel>

      <!-- 사유 -->
      <Border Background="#2A2A3E" CornerRadius="6" Padding="14,10">
        <TextBlock x:Name="ReasonText"
                   TextWrapping="Wrap" FontSize="12" Foreground="#CCCCDD"
                   LineHeight="20"/>
      </Border>

      <!-- 머신 ID -->
      <Border Background="#2A2A3E" CornerRadius="6" Padding="14,10">
        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0"
                     Text="머신 ID" FontSize="11" Foreground="#888899"/>
          <Button Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                  Content="복사" Click="OnCopyMachineId"
                  Background="#3A3A5C" Foreground="#CCCCDD"
                  FontSize="11" Padding="12,4" CornerRadius="4"
                  VerticalAlignment="Center"/>
          <SelectableTextBlock Grid.Row="1" Grid.Column="0"
                               x:Name="MachineIdText"
                               FontSize="15" FontFamily="Menlo, Consolas, monospace"
                               Foreground="#80D4FF" FontWeight="Bold"
                               Margin="0,2,0,0"/>
        </Grid>
      </Border>

      <!-- 안내 -->
      <Border Background="#252538" CornerRadius="6" Padding="14,12">
        <StackPanel Spacing="6">
          <TextBlock Text="📋 라이센스 발급 안내"
                     FontSize="12" FontWeight="Bold" Foreground="#AAAAFF"/>
          <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#BBBBCC" LineHeight="22">
            <Run Text="① 위 머신 ID를 관리자에게 전달하세요."/>
            <LineBreak/>
            <Run Text="② 관리자가 발급한 license.dat 파일을 받으세요."/>
            <LineBreak/>
            <Run Text="③ 파일을 앱 폴더의 license\ 안에 복사 후 재실행하세요."/>
          </TextBlock>
        </StackPanel>
      </Border>

      <!-- 종료 -->
      <Button Content="종료"
              Click="OnExit"
              HorizontalAlignment="Right"
              Background="#D84545" Foreground="White"
              FontSize="12" Padding="24,8" CornerRadius="6"
              Margin="0,4,0,0"/>

    </StackPanel>
  </Border>
</Window>
