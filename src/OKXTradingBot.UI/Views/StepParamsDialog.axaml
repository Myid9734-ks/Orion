<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OKXTradingBot.UI.Views.StepParamsDialog"
        Title="진입 커스텀 설정"
        Width="620" MinHeight="200"
        MaxHeight="800"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackground}">

  <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="16">

    <!-- 안내 문구 -->
    <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,12">
      <TextBlock Text="진입 간격 / 금액 배분 커스텀 설정"
                 FontSize="13" FontWeight="Bold"
                 Foreground="{DynamicResource TextPrimary}"/>
      <TextBlock Text="배수: 이전 회차 대비 배수 입력 (예: 2 → 이전의 2배). 피보나치: 비율 직접 입력."
                 FontSize="11"
                 Foreground="{DynamicResource TextSecondary}"/>
    </StackPanel>

    <!-- 금액 배분 모드 선택 -->
    <Border Grid.Row="1"
            Background="{DynamicResource CardBackground}"
            BorderBrush="{DynamicResource CardBorder}"
            BorderThickness="1" CornerRadius="6"
            Padding="10,8" Margin="0,0,0,10">
      <StackPanel Spacing="6">
        <TextBlock Text="금액 배분 모드"
                   FontSize="11" FontWeight="Bold"
                   Foreground="{DynamicResource TextSecondary}"/>
        <Grid ColumnDefinitions="*,*" Height="32">
          <Button Grid.Column="0"
                  Content="배수"
                  Click="OnModeMultiplier"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  CornerRadius="6,0,0,6"
                  FontSize="12" FontWeight="Bold"
                  Padding="0,6"
                  Name="BtnModeMultiplier"/>
          <Button Grid.Column="1"
                  Content="피보나치"
                  Click="OnModeFibonacci"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  CornerRadius="0,6,6,0"
                  FontSize="12" FontWeight="Bold"
                  Padding="0,6"
                  Name="BtnModeFibonacci"/>
        </Grid>
        <TextBlock Name="TotalAmountLabel"
                   FontSize="11"
                   Foreground="{DynamicResource TextSecondary}"/>
      </StackPanel>
    </Border>

    <!-- 헤더 + 행 목록 -->
    <Border Grid.Row="2"
            Background="{DynamicResource CardBackground}"
            BorderBrush="{DynamicResource CardBorder}"
            BorderThickness="1" CornerRadius="6"
            Padding="10,8">
      <StackPanel>
        <!-- 컬럼 헤더: 회차(40) | 진입간격(150) | 배수/비율(150) | 금액(130) -->
        <Grid ColumnDefinitions="40,150,150,130" Margin="0,0,0,6">
          <TextBlock Text="회차"
                     FontSize="11" FontWeight="Bold"
                     Foreground="{DynamicResource TextSecondary}"
                     HorizontalAlignment="Center"/>
          <TextBlock Grid.Column="1" Text="진입 간격 (%)"
                     FontSize="11" FontWeight="Bold"
                     Foreground="{DynamicResource TextSecondary}"
                     HorizontalAlignment="Center"/>
          <TextBlock Grid.Column="2"
                     Name="WeightHeader"
                     FontSize="11" FontWeight="Bold"
                     Foreground="{DynamicResource TextSecondary}"
                     HorizontalAlignment="Center"
                     IsVisible="False"/>
          <TextBlock Grid.Column="3"
                     Name="AmountHeader"
                     Text="금액 (USDT)"
                     FontSize="11" FontWeight="Bold"
                     Foreground="{DynamicResource TextSecondary}"
                     HorizontalAlignment="Center"
                     IsVisible="False"/>
        </Grid>

        <!-- 데이터 행 -->
        <ScrollViewer MaxHeight="460" VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding Rows}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid ColumnDefinitions="40,150,150,130" Margin="0,3">
                  <!-- 단계 번호 -->
                  <Border Background="{DynamicResource AppBackground}"
                          CornerRadius="4"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Padding="6,2">
                    <TextBlock Text="{Binding Step}"
                               FontSize="12" FontWeight="Bold"
                               Foreground="{DynamicResource AccentColor}"
                               HorizontalAlignment="Center"/>
                  </Border>
                  <!-- 진입 간격 -->
                  <NumericUpDown Grid.Column="1"
                                 Value="{Binding Gap}"
                                 Minimum="0.1" Maximum="20" Increment="0.1"
                                 FormatString="F2"
                                 FontSize="12" FontWeight="Bold"
                                 Margin="3,0"
                                 IsEnabled="{Binding GapEditable}"/>
                  <!-- 배수/비율 (배수·피보나치 모드에서만 표시) -->
                  <NumericUpDown Grid.Column="2"
                                 Value="{Binding Weight}"
                                 Minimum="0.1" Maximum="9999" Increment="0.5"
                                 FormatString="F1"
                                 FontSize="12" FontWeight="Bold"
                                 Margin="3,0"
                                 IsVisible="{Binding ShowWeight}"
                                 IsEnabled="{Binding WeightEditable}"/>
                  <!-- 계산된 금액 (배수·피보나치에서만 표시, 읽기전용) -->
                  <Border Grid.Column="3"
                          Background="{DynamicResource AppBackground}"
                          CornerRadius="4"
                          VerticalAlignment="Center"
                          Margin="3,0"
                          Padding="8,4"
                          IsVisible="{Binding ShowWeight}">
                    <StackPanel Spacing="1">
                      <TextBlock Text="{Binding AmountDisplay}"
                                 FontSize="12" FontWeight="Bold"
                                 Foreground="{Binding AmountColor}"
                                 HorizontalAlignment="Center"/>
                      <TextBlock Text="{Binding KrwDisplay}"
                                 FontSize="10"
                                 Foreground="{DynamicResource AccentColor}"
                                 Opacity="0.8"
                                 HorizontalAlignment="Center"
                                 IsVisible="{Binding KrwDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>
                  </Border>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </StackPanel>
    </Border>

    <!-- 하단 버튼 -->
    <Grid Grid.Row="3" ColumnDefinitions="*,8,Auto,8,Auto" Margin="0,12,0,0">
      <Button Grid.Column="0"
              Content="균등값으로 초기화"
              Click="OnReset"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              Padding="0,9" CornerRadius="6"
              FontSize="12"
              Background="{DynamicResource CardBorder}"
              Foreground="{DynamicResource TextSecondary}"/>
      <Button Grid.Column="2"
              Content="취소"
              Click="OnCancel"
              Padding="20,9" CornerRadius="6"
              FontSize="12"
              Background="{DynamicResource CardBorder}"
              Foreground="{DynamicResource TextSecondary}"/>
      <Button Grid.Column="4"
              Content="확인"
              Click="OnConfirm"
              Padding="20,9" CornerRadius="6"
              FontSize="12" FontWeight="Bold"
              Background="{DynamicResource AccentColor}"
              Foreground="White"/>
    </Grid>

  </Grid>
</Window>
